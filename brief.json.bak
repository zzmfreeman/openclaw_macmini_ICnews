  "glossary": [
    {
      "term": "High-NA EUV",
      "desc": "数值孔径（NA）提升至0.55的新一代极紫外光刻机，由ASML独家供应，支持2nm以下精密图形化，每台售价超4亿美元。"
    },
    {
      "term": "SiC（碳化硅）",
      "desc": "第三代宽禁带半导体材料，耐高压高温，主要用于电动车逆变器和充电桩，市场增速显著高于传统硅器件。"
    },
    {
      "term": "CPO（Co-Packaged Optics）",
      "desc": "共封装光学，将光收发器与交换芯片封装在同一基板，大幅降低AI数据中心互连功耗与延迟，被视为下一代AI网络标准。"
    },
    {
      "term": "HBM4E",
      "desc": "第六代高带宽存储，较HBM4进一步提升容量与带宽，主要用于AI训练芯片，预计2026-2027年量产。"
    },
    {
      "term": "GAA（Gate-All-Around）",
      "desc": "环绕栅晶体管结构，是3nm以下制程的核心架构创新，泄漏电流比FinFET更低，需大幅增加ALD沉积步骤。"
    },
    {
      "term": "SBTi（科学碳目标倡议）",
      "desc": "企业设定与巴黎协定1.5°C目标对齐的碳减排路线图的国际认证框架，正成为大型Fab供应商准入要求之一。"
    }
  ],
  "footer": "IC早报 · v20260314-0600 · 数据来源：NewsAPI · 生成时间：2026-03-14 06:00 Asia/Shanghai"
